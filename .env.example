# PORT: The port the proxy server will listen on (default 3000).
PORT=3000

# UPSTREAM_URL: The target LLM API base URL to proxy to.
UPSTREAM_URL="http://127.0.0.1:8832"

# BYPASS_URL: Optional URL to send a copy of all processed requests to.
BYPASS_URL=""

# AUTO_MODE: Whether to automatically release requests (true/false).
AUTO_MODE="false"
